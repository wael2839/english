# ============================================================
# إعدادات المشروع — انسخ هذا الملف إلى .env وعدّل القيم
# ============================================================

# 1) الموقع
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# 2) الجلسة
# استخدم قيمة عشوائية طويلة في الإنتاج.
AUTH_SECRET=change-me-to-a-long-random-secret

# 3) قاعدة البيانات MySQL
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=english_grammar
DB_SSL=false

# Hostinger example:
# DB_HOST=localhost
# DB_PORT=3306
# DB_USER=u123456789_grammar
# DB_PASSWORD=your-database-password
# DB_NAME=u123456789_grammar
# DB_SSL=false

# If you use a full connection string, DB_* values override it when set.
# DATABASE_URL=mysql://USER:PASSWORD@HOST:3306/DB_NAME

# 4) استعادة كلمة المرور
PASSWORD_RESET_COOLDOWN_MINUTES=10

# 5) البريد SMTP
SMTP_HOST=smtp.example.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=noreply@example.com
SMTP_PASS=your-smtp-password
SMTP_FROM=noreply@example.com
SMTP_FROM_NAME=المرجع التفاعلي لقواعد الإنجليزية

# 6) خلف بعض بروكسيات الاستضافة فقط
# إذا نجح الدخول لكن الكوكي لا تُحفظ، جرّب:
# COOKIE_SECURE=false
