# ============================================================
# إعدادات المشروع — انسخ هذا الملف إلى .env وعدّل القيم
# ============================================================

# ------------------------------------------------------------
# 1) الموقع
# ------------------------------------------------------------
# محلي:  http://localhost:3000
# استضافة: https://english.waelaloush.com
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ------------------------------------------------------------
# 2) الجلسة (مطلوب)
# ------------------------------------------------------------
# نص عشوائي لا يقل عن 16 حرفًا — غيّره في الإنتاج
AUTH_SECRET=change-me-to-a-long-random-secret

# ------------------------------------------------------------
# 3) قاعدة البيانات MySQL (مطلوب)
# ------------------------------------------------------------
# محلي (XAMPP):
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=english_grammar
DB_SSL=false

# استضافة (Hostinger) — مثال:
# DB_HOST=mysql.hostinger.com
# DB_PORT=3306
# DB_USER=u123456789_user
# DB_PASSWORD=your-db-password
# DB_NAME=u123456789_english
# DB_SSL=true
#
# ملاحظة DB_SSL:
#   false  = بدون SSL (مناسب للمحلي)
#   true   = مع SSL ويتسامح مع شهادة الاستضافة (موصى به لـ Hostinger)
#   strict = تحقق صارم من الشهادة (نادرًا ما يُحتاج)

# اختياري: رابط كامل بدل المتغيرات أعلاه
# DATABASE_URL=mysql://USER:PASSWORD@HOST:3306/DB_NAME?sslaccept=accept_invalid_certs

# ------------------------------------------------------------
# 4) استعادة كلمة المرور
# ------------------------------------------------------------
# الحد الأدنى بين طلبين لنفس الحساب (بالدقائق)
PASSWORD_RESET_COOLDOWN_MINUTES=10

# ------------------------------------------------------------
# 5) البريد SMTP (لاستعادة كلمة المرور)
# ------------------------------------------------------------
SMTP_HOST=smtp.example.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=noreply@example.com
SMTP_PASS=your-smtp-password

# البريد الظاهر كمرسل
SMTP_FROM=noreply@example.com

# الاسم الظاهر للمستلم (اختياري)
SMTP_FROM_NAME=المرجع التفاعلي لقواعد الإنجليزية
