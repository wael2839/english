# Public site URL (used in password-reset emails)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# MySQL — each setting on its own line
# DATABASE_URL is built automatically from these (no need to set it)
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=english_grammar
# On shared hosting set the real MySQL host (NOT 127.0.0.1) and enable SSL if required:
# DB_HOST=mysql.example.com
# DB_SSL=true

# Optional override (if set, takes priority over DB_* above):
# DATABASE_URL="mysql://root:YOUR_PASSWORD@127.0.0.1:3306/english_grammar"

# Session signing secret (min 16 characters) — change in production
AUTH_SECRET="change-me-to-a-long-random-secret"

# Password reset — one link per account during this period
PASSWORD_RESET_COOLDOWN_MINUTES=10

# SMTP — password recovery emails
SMTP_HOST="smtp.example.com"
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER="noreply@example.com"
SMTP_PASS="your-smtp-password"
SMTP_FROM="المرجع التفاعلي <noreply@example.com>"
