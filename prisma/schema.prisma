generator client {
  provider      = "prisma-client-js"
  // native = local machine; debian/rhel = Hostinger Linux Node images
  binaryTargets = ["native", "debian-openssl-3.0.x", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id           String         @id @default(cuid())
  email        String         @unique @db.VarChar(191)
  name         String         @db.VarChar(120)
  passwordHash String         @map("password_hash") @db.VarChar(255)
  createdAt    DateTime       @default(now()) @map("created_at")
  updatedAt    DateTime       @updatedAt @map("updated_at")
  passwordChangedAt DateTime? @map("password_changed_at")
  progress     UserProgress?
  resetTokens  PasswordResetToken[]
  sessions     UserSession[]

  @@map("users")
}

model UserSession {
  id        String   @id @default(cuid())
  userId    String   @map("user_id") @db.VarChar(191)
  tokenHash String   @unique @map("token_hash") @db.VarChar(64)
  userAgent String?  @map("user_agent") @db.VarChar(255)
  ipHash    String?  @map("ip_hash") @db.VarChar(64)
  expiresAt DateTime @map("expires_at")
  revokedAt DateTime? @map("revoked_at")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("user_sessions")
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String   @map("user_id") @db.VarChar(191)
  tokenHash String   @unique @map("token_hash") @db.VarChar(64)
  expiresAt DateTime @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime @default(now()) @map("created_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("password_reset_tokens")
}

model AuthRateLimit {
  id        String   @id @default(cuid())
  action    String   @db.VarChar(40)
  keyHash   String   @map("key_hash") @db.VarChar(64)
  attempts  Int      @default(0)
  resetAt   DateTime @map("reset_at")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([action, keyHash])
  @@index([resetAt])
  @@map("auth_rate_limits")
}

model UserProgress {
  id        String   @id @default(cuid())
  userId    String   @unique @map("user_id") @db.VarChar(191)
  data      Json
  updatedAt DateTime @updatedAt @map("updated_at")
  createdAt DateTime @default(now()) @map("created_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_progress")
}
